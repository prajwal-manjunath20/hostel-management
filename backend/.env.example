# ============================================================
# Hostel Management System — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=production          # production | development
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────
# Use a connection string from MongoDB Atlas (or self-hosted).
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 characters for production.
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_64_CHARS_MIN
JWT_EXPIRES_IN=24h

# ── Frontend / CORS ──────────────────────────────────────────
# The exact origin of your deployed frontend (no trailing slash).
# Used for CORS allow-list and email link generation.
FRONTEND_URL=https://yourdomain.com

# ── Email (Gmail SMTP via App Password) ──────────────────────
# Create a Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASS=REPLACE_WITH_APP_PASSWORD
